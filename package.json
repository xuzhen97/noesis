{
  "name": "noesis",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "pnpm@10.25.0",
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  },
  "scripts": {
    "build": "pnpm -r --sort build",
    "test": "pnpm build && pnpm -r --sort test && pnpm check:boundaries",
    "check:boundaries": "node scripts/check-boundaries.mjs",
    "verify": "pnpm test",
    "build:distribution": "pnpm build && node scripts/build-distribution.mjs",
    "verify:distribution": "node scripts/verify-distribution.mjs"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.0"
  }
}
